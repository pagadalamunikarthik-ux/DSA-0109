#include <stdio.h>

int main() {
    int num, temp, digit, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;

    // Find sum of digits
    while (temp > 0) {
        digit = temp % 10;
        sum = sum + digit;
        temp = temp / 10;
    }

    // Check Harshad condition
    if (num % sum == 0) {
        printf("%d is a Harshad Number\n", num);
    } else {
        printf("%d is NOT a Harshad Number\n", num);
    }

    return 0;
}
