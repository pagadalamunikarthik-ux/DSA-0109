#include <iostream>
using namespace std;

int main() {
    int start, end, i, j, prime;

    cout << "Enter the starting number: ";
    cin >> start;

    cout << "Enter the ending number: ";
    cin >> end;

    cout << "Prime numbers are: ";

    for (i = start; i <= end; i++) {
        if (i < 2)
            continue;

        prime = 1;

        for (j = 2; j <= i / 2; j++) {
            if (i % j == 0) {
                prime = 0;
                break;
            }
        }

        if (prime == 1)
            cout << i << " ";
    }

    return 0;
}
